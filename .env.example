# Project identity
COMPOSE_PROJECT_NAME=pressyard
WP_HOSTNAME=pressyard.localhost
WP_URL=http://pressyard.localhost
HOST_RESOLUTION_MODE=localhost-only

# Direct access ports
WORDPRESS_PUBLISHED_PORT=8080
WORDPRESS_BIND_ADDRESS=127.0.0.1
ADMINER_PUBLISHED_PORT=18080

# Shared proxy
PROXY_PROJECT_NAME=pressyard-proxy
PROXY_BIND_ADDRESS=127.0.0.1
PROXY_HTTP_PORT=80
PROXY_DASHBOARD_PORT=8089
PROXY_CONFIG_DIR=

# Runtime images
WORDPRESS_IMAGE=wordpress:6.8.2-php8.2-apache
WORDPRESS_CLI_IMAGE=wordpress:cli-php8.2
MARIADB_IMAGE=mariadb:11.4.10
TRAEFIK_IMAGE=traefik:v3.1
ADMINER_IMAGE=adminer:4.8.1-standalone

# Auto-generation controls
AUTO_NAMESPACE=true
AUTO_PORT=true
AUTO_ADMINER_PORT=true

# Database
MARIADB_ROOT_PASSWORD=change-this-root-password
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-this-db-password
WORDPRESS_TABLE_PREFIX=wp_

# WordPress install
WP_SITE_TITLE=Local WordPress
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change-this-admin-password
WP_ADMIN_EMAIL=admin@example.com
WP_DEBUG=true
